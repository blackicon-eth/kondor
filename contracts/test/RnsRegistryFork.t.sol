pragma solidity ^0.8.28;

import {Test, console} from "forge-std/Test.sol";
import {RnsRegistry} from "../src/RnsRegistry.sol";
import {SimpleAccount} from "../src/SimpleAccount.sol";
import {IERC20} from "@openzeppelin/contracts/token/ERC20/IERC20.sol";

/// @dev Fork tests against Base mainnet using the CRE simulation forwarder.
///      Paste the ENCODED_REPORT_CALLDATA from `cre workflow simulate` output
///      to test the full onReport → deploy SA → approve → swap/supply flow.
contract RnsRegistryForkTest is Test {
    // Base mainnet KeystoneForwarder (CRE simulation)
    address constant FORWARDER = 0x5E342a8438B4f5d39e72875FCee6f76B39CCE548;

    // Base mainnet tokens
    IERC20 constant USDC = IERC20(0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913);
    IERC20 constant WETH = IERC20(0x4200000000000000000000000000000000000006);
    IERC20 constant LINK = IERC20(0x88Fb150BDc53A65fe94Dea0c9BA0a6dAf8C6e196);
    IERC20 constant aBasUSDC = IERC20(0x4e65fE4DbA92790696d040ac24Aa414708F5c0AB);

    // Portals router on Base
    address constant PORTALS_ROUTER = 0xb0324286B3ef7dDdC93Fb2fF7c8B7B8a3524803c;

    RnsRegistry registry;
    uint256 baseFork;

    address receiver = 0x4070b28eD6c81ee2aD142BdC41d9DF87EDDcEA88;

    function setUp() public {
        baseFork = vm.createFork("https://mainnet.base.org");
        vm.selectFork(baseFork);

        registry = new RnsRegistry(FORWARDER);
    }

    // -------------------------------------------------------------------
    // Precompute CREATE2 address for a subdomain
    // -------------------------------------------------------------------

    /// @dev Run with `forge test --match-test test_fork_predictAddress -vvv`
    ///      to get the SA address for "fernandello". Use this as `sender` in payload.json.
    function test_fork_predictAddress() public view {
        string memory subdomain = "fernandello";

        address predicted = registry.predictAddress(subdomain);

        console.log("=== CREATE2 Prediction ===");
        console.log("Registry:", address(registry));
        console.log("Subdomain:", subdomain);
        console.log("SA address:", predicted);
        console.log("==========================");
        console.log("");
        console.log("Set in payload.json:");
        console.log("  sender:", receiver);
    }

    // -------------------------------------------------------------------
    // Helper: fund SA with USDC
    // -------------------------------------------------------------------

    function _fundSA(string memory subdomain, uint256 amount) internal returns (address sa) {
        sa = registry.createAccount(subdomain, receiver);
        deal(address(USDC), sa, amount);
        assertEq(USDC.balanceOf(sa), amount, "SA should have USDC");
    }

    // -------------------------------------------------------------------
    // Test: onReport deploys SA and executes batch on fork
    // -------------------------------------------------------------------

    /// @dev Simulates the CRE flow: forwarder calls onReport with encoded
    ///      (subdomain, owner, targets[], values[], calldatas[])
    ///      where the batch is [approve, swap, approve, supply, approve, swap]
    function test_fork_onReport_deploysAndExecutesBatch() public {
        // Use subdomain that doesn't CREATE2-collide with receiver (fernandello does)
        string memory subdomain = "sanity-check";

        // Predict the SA address and fund it
        address sa = registry.predictAddress(subdomain);
        deal(address(USDC), sa, 100e6);

        address recipient = address(0xBEEF);

        // Build a simple batch: approve + transfer USDC to recipient (sanity test)
        address[] memory targets = new address[](2);
        uint256[] memory values = new uint256[](2);
        bytes[] memory calldatas = new bytes[](2);

        targets[0] = address(USDC);
        values[0] = 0;
        calldatas[0] = abi.encodeCall(IERC20.approve, (recipient, 10e6));

        targets[1] = address(USDC);
        values[1] = 0;
        calldatas[1] = abi.encodeCall(IERC20.transfer, (recipient, 10e6));

        bytes memory report = abi.encode(subdomain, receiver, targets, values, calldatas);

        uint256 recipientBefore = USDC.balanceOf(recipient);

        vm.prank(FORWARDER);
        registry.onReport("", report);

        // SA should be deployed
        address deployed = registry.getAccount(subdomain);
        assertTrue(deployed != address(0), "SA should be deployed");
        assertEq(deployed, sa, "SA address should match prediction");

        // Recipient should have gotten 10 USDC
        assertEq(USDC.balanceOf(recipient) - recipientBefore, 10e6, "recipient got 10 USDC");

        // SA should have 90 USDC left
        assertEq(USDC.balanceOf(deployed), 90e6, "SA has 90 USDC remaining");
    }

    /// @dev Test that an existing SA can execute batch via onReport
    function test_fork_onReport_existingSA() public {
        address sa = _fundSA("existing-test", 50e6);

        address[] memory targets = new address[](1);
        uint256[] memory values = new uint256[](1);
        bytes[] memory calldatas = new bytes[](1);

        targets[0] = address(USDC);
        values[0] = 0;
        calldatas[0] = abi.encodeCall(IERC20.transfer, (receiver, 25e6));

        bytes memory report = abi.encode("existing-test", receiver, targets, values, calldatas);

        uint256 receiverBefore = USDC.balanceOf(receiver);

        vm.prank(FORWARDER);
        registry.onReport("", report);

        assertEq(USDC.balanceOf(receiver) - receiverBefore, 25e6);
        assertEq(USDC.balanceOf(sa), 25e6);
    }

    /// @dev Test approve + Portals swap on fork using real calldata.
    ///      To use: paste the ENCODED_REPORT_CALLDATA from simulation output.
    ///      This test builds the batch manually as a reference.
    function test_fork_onReport_approveAndSwapViaPortals() public {
        string memory subdomain = "portals-test";
        address sa = registry.predictAddress(subdomain);
        deal(address(USDC), sa, 100e6);

        // Build: approve Portals router for 10 USDC, then swap 10 USDC → WETH
        // The actual Portals calldata would come from the API, here we just test
        // the approve part works and the SA can call external contracts
        address[] memory targets = new address[](1);
        uint256[] memory values = new uint256[](1);
        bytes[] memory calldatas = new bytes[](1);

        // Just test approve works on fork
        targets[0] = address(USDC);
        values[0] = 0;
        calldatas[0] = abi.encodeCall(IERC20.approve, (PORTALS_ROUTER, 10e6));

        bytes memory report = abi.encode(subdomain, receiver, targets, values, calldatas);

        vm.prank(FORWARDER);
        registry.onReport("", report);

        address deployed = registry.getAccount(subdomain);
        assertEq(USDC.allowance(deployed, PORTALS_ROUTER), 10e6, "Portals router approved");
    }

    // -------------------------------------------------------------------
    // Test: real CRE simulation calldata
    // -------------------------------------------------------------------

    /// @dev Real encoded report from CRE simulation output.
    ///      Batch: 3 approvals + 3 portal txs (swap WETH, supply aBasUSDC, swap LINK)
    function test_fork_onReport_rawSimulationCalldata() public {
        bytes memory report = hex"";

        // Decode subdomain to predict + fund SA
        (string memory subdomain,,,,) = abi.decode(report, (string, address, address[], uint256[], bytes[]));
        address sa = registry.predictAddress(subdomain);
        deal(address(USDC), sa, 100e6);

        uint256 receiverWethBefore = WETH.balanceOf(receiver);
        uint256 receiverLinkBefore = LINK.balanceOf(receiver);

        // Execute as forwarder
        vm.prank(FORWARDER);
        registry.onReport("", report);

        // SA should be deployed
        address deployed = registry.getAccount(subdomain);
        assertTrue(deployed != address(0), "SA deployed");
        assertEq(deployed, sa, "SA matches prediction");

        // Log all balances
        console.log("=== Post-execution balances ===");
        console.log("SA USDC:", USDC.balanceOf(deployed));
        console.log("SA WETH:", WETH.balanceOf(deployed));
        console.log("SA LINK:", LINK.balanceOf(deployed));
        console.log("SA aBasUSDC:", aBasUSDC.balanceOf(deployed));
        console.log("Receiver WETH gained:", WETH.balanceOf(receiver) - receiverWethBefore);
        console.log("Receiver LINK gained:", LINK.balanceOf(receiver) - receiverLinkBefore);
    }
}
