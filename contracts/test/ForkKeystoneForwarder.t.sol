pragma solidity ^0.8.28;

import {Test, console2} from "forge-std/Test.sol";

/// @notice Fork Sepolia, impersonate a real sender, low-level `call` the Keystone forwarder.
/// @dev Paste your full tx `input` (0x...) into `callData` below, then run:
///      forge test --match-contract ForkKeystoneForwarderTest --match-test test_forwarderCall -vvvv
///      Add `SEPOLIA_RPC_URL` in .env if you want a different RPC than the default.
contract ForkKeystoneForwarderTest is Test {
    string internal constant DEFAULT_SEPOLIA_RPC = "https://1rpc.io/sepolia";

    address internal constant TX_SENDER = 0xDD7D64BFd13EF3b733374Fc8DE9B9C651487a15D;
    address internal constant KEYSTONE_FORWARDER = 0x15fC6ae953E024d975e77382eEeC56A9101f9F88;

    /// @dev Replace with your full calldata (e.g. copy `Input Data` from Etherscan / Tenderly).
    bytes internal callData =
        hex"";

    function test_forwarderCall() public {
        string memory rpc = vm.envOr("SEPOLIA_RPC_URL", DEFAULT_SEPOLIA_RPC);
        vm.createSelectFork(rpc);

        vm.deal(TX_SENDER, 50 ether);
        vm.startPrank(TX_SENDER);

        (bool ok, bytes memory returndata) = KEYSTONE_FORWARDER.call{value: 0}(callData);

        console2.log("ok:", ok);
        console2.logBytes(returndata);

        vm.stopPrank();
    }
}
